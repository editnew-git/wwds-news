---
import { getCollection } from 'astro:content';
import SiteLayout from '../layouts/SiteLayout.astro';
import { getPublicAsset } from '../lib/publicAsset';

const posts = (await getCollection('news', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const latest = posts[0];
const latestImage = getPublicAsset(latest?.data.image);
---

<SiteLayout title="WWDS — Newsroom">
  <section class="news-hero">
    <p class="eyebrow">WWDS / Newsroom</p>
    <h1 class="display">Signals<br />that matter.</h1>
    <div class="hero-foot meta">
      <span>Worldwide Digital Signage</span>
      <span>Updates, releases &amp; perspective</span>
    </div>
  </section>

  {latest && (
    <section class="release-list" aria-label="Latest news">
      <a class="release-card" href={`/news/${latest.data.slug}`}>
        {latestImage && <img class="card-image" src={latestImage} alt="" loading="lazy" />}
        <span class="card-index meta">01 / Latest</span>
        <div>
          <h2 class="card-title">{latest.data.title}</h2>
          {latest.data.excerpt && <p class="card-excerpt">{latest.data.excerpt}</p>}
        </div>
        <span class="card-arrow" aria-hidden="true">↗</span>
      </a>
    </section>
  )}
</SiteLayout>
